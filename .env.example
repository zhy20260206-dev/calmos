# CalmOS 本地运行环境变量
# 复制此文件为 .env.local，填入真实值后运行 vercel dev
#
# 获取方式：
#   DeepSeek API Key → https://platform.deepseek.com → API Keys
#   Supabase 信息    → https://supabase.com/dashboard/project/rjxbcxcnjnwplroytnan → Settings → API

# 必填：DeepSeek API Key（去 platform.deepseek.com 创建）
DEEPSEEK_API_KEY=sk-你的key填这里

# 可选：模型名（默认 deepseek-chat，也可用 deepseek-reasoner）
DEEPSEEK_MODEL=deepseek-chat

# 必填：Supabase 项目 URL
SUPABASE_URL=https://rjxbcxcnjnwplroytnan.supabase.co

# 必填：Supabase 匿名公钥（publishable key，可以公开）
SUPABASE_ANON_KEY=sb_publishable_zFObYEugRZYsooLN-OxOUQ_9O8OIi5r
